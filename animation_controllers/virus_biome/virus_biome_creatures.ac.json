{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.virus_biome.ground_hostile": {
            "initial_state": "idle",
            "states": {
                "idle": {
                    "animations": ["anim_idle"],
                    "transitions": [
                        { "attacking": "query.is_delayed_attacking" },
                        { "walking": "query.modified_move_speed > 0.1" }
                    ],
                    "blend_transition": 0.2
                },
                "walking": {
                    "animations": ["anim_walk"],
                    "transitions": [
                        { "attacking": "query.is_delayed_attacking" },
                        { "idle": "query.modified_move_speed < 0.05" }
                    ],
                    "blend_transition": 0.2
                },
                "attacking": {
                    "animations": ["anim_attack"],
                    "transitions": [
                        { "idle": "!query.is_delayed_attacking" }
                    ],
                    "blend_transition": 0.1
                }
            }
        },
        "controller.animation.virus_biome.ground_hostile_runner": {
            "initial_state": "idle",
            "states": {
                "idle": {
                    "animations": ["anim_idle"],
                    "transitions": [
                        { "attacking": "query.is_delayed_attacking" },
                        { "running": "query.modified_move_speed >= 0.4" },
                        { "walking": "query.modified_move_speed > 0.1" }
                    ],
                    "blend_transition": 0.2
                },
                "walking": {
                    "animations": ["anim_walk"],
                    "transitions": [
                        { "attacking": "query.is_delayed_attacking" },
                        { "running": "query.modified_move_speed >= 0.4" },
                        { "idle": "query.modified_move_speed < 0.05" }
                    ],
                    "blend_transition": 0.2
                },
                "running": {
                    "animations": ["anim_run"],
                    "transitions": [
                        { "attacking": "query.is_delayed_attacking" },
                        { "idle": "query.modified_move_speed < 0.05" },
                        { "walking": "query.modified_move_speed < 0.35" }
                    ],
                    "blend_transition": 0.15
                },
                "attacking": {
                    "animations": ["anim_attack"],
                    "transitions": [
                        { "idle": "!query.is_delayed_attacking" }
                    ],
                    "blend_transition": 0.1
                }
            }
        },
        "controller.animation.virus_biome.mutated_host_move": {
            "initial_state": "idle",
            "states": {
                "idle": {
                    "animations": ["anim_idle"],
                    "transitions": [
                        { "dying": "!query.is_alive" },
                        { "attacking": "query.is_delayed_attacking" },
                        { "running": "query.modified_move_speed >= 0.4" },
                        { "walking": "query.modified_move_speed > 0.1" }
                    ],
                    "blend_transition": 0.2
                },
                "walking": {
                    "animations": ["anim_walk"],
                    "transitions": [
                        { "dying": "!query.is_alive" },
                        { "attacking": "query.is_delayed_attacking" },
                        { "running": "query.modified_move_speed >= 0.4" },
                        { "idle": "query.modified_move_speed < 0.05" }
                    ],
                    "blend_transition": 0.2
                },
                "running": {
                    "animations": ["anim_run"],
                    "transitions": [
                        { "dying": "!query.is_alive" },
                        { "attacking": "query.is_delayed_attacking" },
                        { "idle": "query.modified_move_speed < 0.05" },
                        { "walking": "query.modified_move_speed < 0.35" }
                    ],
                    "blend_transition": 0.15
                },
                "attacking": {
                    "animations": ["anim_attack"],
                    "transitions": [
                        { "dying": "!query.is_alive" },
                        { "idle": "!query.is_delayed_attacking" }
                    ],
                    "blend_transition": 0.1
                },
                "dying": {
                    "blend_transition": 0.15
                }
            }
        },
        "controller.animation.virus_biome.mutated_host_death": {
            "initial_state": "alive",
            "states": {
                "alive": {
                    "transitions": [
                        { "dying": "!query.is_alive" }
                    ]
                },
                "dying": {
                    "animations": ["anim_death"],
                    "blend_transition": 0.1
                }
            }
        },
        "controller.animation.virus_biome.flyer_hostile": {
            "initial_state": "idle",
            "states": {
                "idle": {
                    "animations": ["anim_idle"],
                    "transitions": [
                        { "attacking": "query.is_delayed_attacking" },
                        { "flying": "!query.is_on_ground || query.modified_move_speed > 0.1" }
                    ],
                    "blend_transition": 0.25
                },
                "flying": {
                    "animations": ["anim_fly"],
                    "transitions": [
                        { "attacking": "query.is_delayed_attacking" },
                        { "idle": "query.is_on_ground && query.modified_move_speed < 0.05" }
                    ],
                    "blend_transition": 0.25
                },
                "attacking": {
                    "animations": ["anim_attack"],
                    "transitions": [
                        { "flying": "!query.is_delayed_attacking && (!query.is_on_ground || query.modified_move_speed > 0.1)" },
                        { "idle": "!query.is_delayed_attacking" }
                    ],
                    "blend_transition": 0.15
                }
            }
        }
    }
}
